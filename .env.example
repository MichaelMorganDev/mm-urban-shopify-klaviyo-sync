# Shopify (from Partner Dashboard / `shopify app env`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_customers
SHOPIFY_APP_URL=

# Database — required. Use Postgres in production (Render Postgres, Neon, etc.).
# Local: `docker compose up -d` then use the URL below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_app

# Klaviyo sync
KLAVIYO_API_KEY=
# Optional Klaviyo API revision header (default 2024-10-15)
# KLAVIYO_API_REVISION=
